#!/usr/bin/env bash

set -o pipefail
set -o errexit
set -o nounset
set -o errtrace
shopt -s inherit_errexit

c_rebase_commands_file=$(mktemp)
c_help="Usage: $(basename "$0") [-h|--help] [--non-interactive] <filename> [subject_suffix]

Rewrites the history of a repository, merging the commits including a given file into a single commit; this is useful when one wants to keep only the latest version of a file.

Before the operation, the origin is pulled, and the branch rebased. A keypress is required before rewriting the history."

v_filename=
v_subject_suffix=
v_interactive=1      # boolean; false=blank, true=anything else

function decode_cmdline_args {
  local params
  params=$(getopt --options h --long help,non-interactive --name "$(basename "$0")" -- "$@")
  eval set -- "$params"

  while true; do
    case $1 in
      -h|--help)
        echo "$c_help"
        exit 0 ;;
      --non-interactive)
        v_interactive=;
        shift ;;
      --)
        shift
        break ;;
    esac
  done

  case $# in
  1)
    v_filename=$1
    ;;
  2)
    v_filename=$1
    v_subject_suffix=$2
    ;;
  *)
    echo "$c_help"
    exit 1
  esac

  v_filename=$1
}

function register_exit_hook {
  function _exit_hook { rm -f "$c_rebase_commands_file"; }
  trap _exit_hook EXIT
}

function pull_and_rebase_branch {
  echo "Pulling and rebasing..."

  git pull --rebase

  echo
}

function find_first_addition_hash {
  git log --pretty=format:%H -- "$v_filename" | tail -n 1
}

# The merge reorders all the commits not including the file before the first one including it. If
# that first commit also changes other files which a later (reordered) commit depends on, the
# rebase breaks halfway; detect this and bail out before touching the history.
#
function ensure_first_addition_is_movable {
  local first_addition_hash=$1

  local first_other_paths
  first_other_paths=$(
    git diff-tree --no-commit-id --name-only -r "$first_addition_hash" | grep -vxF "$v_filename" || true
  )

  [[ -z $first_other_paths ]] && return 0

  local reordered_paths
  reordered_paths=$(
    git rev-list "$first_addition_hash"..HEAD | while read -r hash; do
      if ! git diff-tree --no-commit-id --name-only -r "$hash" | grep -qxF "$v_filename"; then
        git diff-tree --no-commit-id --name-only -r "$hash"
      fi
    done
  )

  local conflicts
  conflicts=$(comm -12 <(sort -u <<< "$first_other_paths") <(sort -u <<< "$reordered_paths"))

  if [[ -n $conflicts ]]; then
    echo "Error: the first commit adding '$v_filename' ($(git log -1 --format='%h %s' "$first_addition_hash")) also changes files that later commits depend on, so the history can't be merged automatically:" >&2
    while IFS= read -r path; do echo "  $path" >&2; done <<< "$conflicts"
    echo "Rewrite the history manually to give '$v_filename' a dedicated first commit, then re-run." >&2
    exit 1
  fi
}

function print_history_from_first_addition {
  local first_addition_hash=$1

  local history_log
  history_log=$(git log --reverse --pretty=format:'%h %s' "$first_addition_hash"~..)

  echo "#################################################"
  echo "# Original history (old to new, $(wc -l <<< "$history_log"))"
  echo "#################################################"
  echo
  echo "$history_log"
  echo
}

function prepare_rebase_commands {
  local first_addition_hash=$1

  local all_commits file_commits
  all_commits=$(git log --reverse --pretty=format:'pick %H %s' "$first_addition_hash"~..)
  file_commits=$(git log --reverse --pretty=format:'pick %H %s' "$first_addition_hash"~.. -- "$v_filename")

  # Pick the commits not including the file in their original order, then the first commit
  # including it, then fixup all the other commits including it; the merged commit ends up as
  # HEAD, which rename_head_message() amends.
  #
  {
    grep -vxF -f <(printf '%s\n' "$file_commits") <<< "$all_commits" || true
    head -n 1 <<< "$file_commits"
    sed '1d; s/^pick/fixup/' <<< "$file_commits"
  } > "$c_rebase_commands_file"
}

function print_rebase_commands {
  echo "#################################################"
  echo "# Rebase commands (old to new, $(wc -l < "$c_rebase_commands_file"))"
  echo "#################################################"
  echo
  cat "$c_rebase_commands_file"
  echo
}

function ask_keypress {
  echo "Press any key to continue..."

  read -rsn1
}

function perform_rebase {
  local first_addition_hash=$1

  # Include $first_addition_hash, so it will be removed.
  #
  GIT_SEQUENCE_EDITOR="cp $c_rebase_commands_file" git rebase -i "$first_addition_hash"~
}

function rename_head_message {
  local message="Add $v_filename"

  if [[ -n $v_subject_suffix ]]; then
    message+=" $v_subject_suffix"
  fi

  # Easiest way to rename a commit non-interactively
  #
  git commit --amend --message "$message"
}

function print_diff_with_origin {
  echo "Difference with origin:"
  git diff origin/"$(git rev-parse --abbrev-ref HEAD)"
}

function push_repository {
  git push --force
}


function main {
  local first_addition_hash

  register_exit_hook

  # Guard before pulling, so that an unmergeable history leaves the repository untouched.
  ensure_first_addition_is_movable "$(find_first_addition_hash)"

  pull_and_rebase_branch

  first_addition_hash=$(find_first_addition_hash)

  print_history_from_first_addition "$first_addition_hash"

  prepare_rebase_commands "$first_addition_hash"

  print_rebase_commands

  if [[ -n $v_interactive ]]; then
    ask_keypress
  fi

  perform_rebase "$first_addition_hash"

  rename_head_message

  push_repository
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  decode_cmdline_args "$@"
  main
fi
