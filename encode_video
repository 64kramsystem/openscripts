#!/usr/bin/env bash

# shellcheck disable=1007   # silly assignment stuff

set -o pipefail
set -o errexit
set -o nounset
set -o errtrace
shopt -s inherit_errexit

c_default_extension=mkv
# The combinations h265:slow+25 vs. av1:4+29 yield similar size, with av1 being much faster and
# significantly higher quality.
declare -A c_default_preset=(
  [h265]=slow # FPS: M4: slow=18
  [av1]=4     # FPS: M4: 4=72, 3=49, 2=28
)
declare -A c_default_crf=(
  [h265]=25
  [av1]=29
)
c_tmp_extension=tmp
# Very roughly tested; set 1 process less than the amount saturating the given CPU.
declare -A c_procs_mapping=(
  [32]=2 # 7950X
  [10]=1 # M4
)
declare -A c_rotation_to_filter=(
  [cw]="transpose=clock"
  [ccw]="transpose=cclock"
)
c_help="Usage: $(basename "$0") [-h|--help] [--encoder h265|av1] [-b|--batch] [-d|--deinterlace] [-s|--square <dar_ratio>] [-r|--resize height_px] [-R|--rotate cw|ccw] [-p|--preset <preset>] [-e|--extension <ext>] [-o|--output-dir <path>] [-k|--keep-input-files] <input> {<input>, ...}

Encodes video files to h265 or AV1 (default), in parallel; copies the audio. Multiple cut ranges re-encode audio to AAC. The number of parallel procs is based on an internal table.
Encoder selection: --encoder av1 (default) uses libsvtav1; --encoder h265 uses libx265.
Default preset/crf: h265=${c_default_preset[h265]}/${c_default_crf[h265]}, av1=${c_default_preset[av1]}/${c_default_crf[av1]}.
The file extension is replaced with '$c_default_extension' (or '--extension', when provided).

Files workflow:

- input files are temporarily renamed
- in case of error/termination
  - output files are deleted
  - input files are renamed back
- in case of success
  - input files are trashed (unless specified)

Video filters:

- deinterlace (performed via yadif)
- convert to square pixels (DAR ratio, e.g. '4/3'); sets SAR to 1
- resize (new height in pixels)
- rotate (90° CW) (WATCH OUT! Applied after resizing)

Cut ranges can be appended to an input filename as '<filename>=<start>-<end>,<start2>-<end2>'.
The <start> and <end> values are timestamps in the '[[hh:]mm:]ss[.sss]' format. Ends can be omitted.

If \$SCRIPTING_ALARM_PROGRAM is defined, it's executed after encoding.

In batch mode, output files are not printed, and the alarm program is not invoked.
"

# For simplicity, temp input and output files are in the same order as the orig input files.
v_orig_input_files=()
v_temp_input_files=()
v_output_files=()
v_file_segments=()

v_parallel_procs=         # numeric
v_video_codec=av1         # "h265" or "av1"
v_batch_mode=             # boolean; false=blank, true=anything else
v_deinterlace=            # boolean; false=blank, true=anything else
v_dar_ratio=              # string
v_resize=                 # numeric; vertical size
v_rotate=                 # "cw"/"ccw"
v_preset=                 # blank means "use codec default"
v_crf=                    # blank means "use codec default"
v_extension=$c_default_extension
v_output_dir=             # optional; when set, has never a trailing slash
v_delete_input_files=1    # boolean; false=blank, true=anything else

function decode_cmdline_args {
  local params
  if ! params=$(getopt --options hbds:r:R:p:e:o:k --long help,encoder:,batch,deinterlace,square:,resize:,rotate:,preset:,extension:,output-dir:,keep-input-files --name "$(basename "$0")" -- "$@"); then
    exit 1
  fi

  eval set -- "$params"

  while true; do
    case $1 in
      -h|--help)
        echo "$c_help"
        exit 0 ;;
      --encoder)
        if [[ ! $2 =~ ^(h265|av1)$ ]]; then
          >&2 echo "Invalid encoder: $2 (valid: h265, av1)"
          exit 1
        fi
        v_video_codec=$2
        shift 2 ;;
      -b|--batch)
        v_batch_mode=1
        shift ;;
      -d|--deinterlace)
        v_deinterlace=1
        shift ;;
      -s|--square)
        v_dar_ratio=$2
        shift 2 ;;
      -r|--resize)
        v_resize=$2
        shift 2 ;;
      -R|--rotate)
        if [[ ! $2 =~ ^(cw|ccw)$ ]]; then
          >&2 echo "Invalid rotation value: $2"
          exit 1
        fi
        v_rotate=$2
        shift 2 ;;
      -p|--preset)
        v_preset=$2
        shift 2 ;;
      -e|--extension)
        v_extension=$2
        shift 2 ;;
      -o|--output-dir)
        v_output_dir=$2
        shift 2 ;;
      -k|--keep-input-files)
        v_delete_input_files=
        shift ;;
      --)
        shift
        break ;;
    esac
  done

  if [[ -z $v_preset ]]; then
    v_preset=${c_default_preset[$v_video_codec]}
  fi

  if [[ -z $v_crf ]]; then
    v_crf=${c_default_crf[$v_video_codec]}
  fi

  if [[ $# -lt 1 ]]; then
    echo "$c_help"
    exit 1
  fi

  if [[ -n $v_dar_ratio && ! $v_dar_ratio =~ ^[[:digit:]]{1,2}/[[:digit:]]{1,2}$ ]]; then
    >&2 echo "Unexpected DAR ratio."
    echo "$c_help"
    exit 1
  fi

  if [[ -n $v_dar_ratio && $v_resize ]]; then
    # There's nothing preventing this, but want to avoid accidents, as typically only one of the two
    # needs to be performed.
    #
    >&2 echo "Changing ratio and resizing can't be performed together"
    echo "$c_help"
    exit 1
  fi

  v_output_dir=${v_output_dir%/}

  local input_file segments maybe_segments
  for input_file in "$@"; do
    segments=
    if [[ $input_file == *=* ]]; then
      maybe_segments=${input_file##*=}
      if segments_are_valid "$maybe_segments"; then
        segments=$maybe_segments
        input_file=${input_file%"=$segments"}
      fi
    fi

    v_orig_input_files+=("$input_file")
    v_file_segments+=("$segments")
  done

  local file
  for file in "${v_orig_input_files[@]}"; do
    v_temp_input_files+=("$file.$c_tmp_extension")

    [[ -n $v_output_dir ]] && file="$v_output_dir/$(basename "$file")"
    v_output_files+=("${file%.*}.$v_extension")
  done

  local processors_count
  processors_count=$(nproc)
  if [[ -v c_procs_mapping[$processors_count] ]]; then
    v_parallel_procs=${c_procs_mapping[$processors_count]}
  else
    >&2 echo "Procs count mapping not found for $processors_count processors."
    exit 1
  fi
}

function validate_segments {
  local segments=$1
  if ! segments_are_valid "$segments"; then
    >&2 echo "Invalid segment format."
    echo "$c_help"
    exit 1
  fi
}

function segments_are_valid {
  local segments=$1 segment
  IFS=, read -ra split_segments <<< "$segments"
  for segment in "${split_segments[@]}"; do
    local timestamp='([[:digit:]]{1,2}:){0,2}[[:digit:]]{1,2}(\.[[:digit:]]+)?'
    if [[ ! $segment =~ ^($timestamp)?-($timestamp)?$ ]]; then
      return 1
    fi
  done
  return 0
}

function check_input_files {
  for file in "${v_orig_input_files[@]}"; do
    # The argument `-of csv=p=0` can return `video,`.
    #
    if [[ $(ffprobe -v error -select_streams v:0 -show_entries stream=codec_type -of default=noprint_wrappers=1:nokey=1 "$file") != "video" ]]; then
      >&2 echo "The input '$file' is not/doesn't contain a video"
      exit 1
    fi
  done
}

function rename_input_files {
  for (( i = 0; i < "${#v_orig_input_files[@]}"; i++ )); do
    mv "${v_orig_input_files[$i]}" "${v_temp_input_files[$i]}"
  done
}

function perform_checks {
  if [[ -n $v_output_dir && ! -d $v_output_dir ]]; then
    >&2 echo "The specified output directory doesn't exist!"
    exit 1
  fi

  for file in "${v_orig_input_files[@]}"; do
    if [[ $file == *$'\n'* || $file == *\"* ]]; then
      >&2 echo "File '$file' includes a newline/double quote!"
      exit 1
    fi
  done

  for file in "${v_output_files[@]}"; do
    if [[ -f $file ]]; then
      >&2 echo "File '$file' exists!"
      exit 1
    fi
  done
}

# Delete output files in case of interruption/error.
#
function register_exit_hooks {
  function _error_exit_hook {
    for file in "${v_output_files[@]}"; do
      rm -f "$file"
    done

    for (( i = 0; i < "${#v_orig_input_files[@]}"; i++ )); do
      if [[ -f "${v_temp_input_files[$i]}" ]]; then
        mv "${v_temp_input_files[$i]}" "${v_orig_input_files[$i]}"
      fi
    done

    echo "
>>> Original files restored."
  }

  trap '[[ $? -ne 0 ]] && _error_exit_hook' EXIT
}

function encode_files {
  local commands=()

  for (( i = 0; i < "${#v_temp_input_files[@]}"; i++ )); do
    commands+=("$(build_ffmpeg_command "${v_temp_input_files[$i]}" "${v_file_segments[$i]}" "${v_output_files[$i]}")")
  done

  printf '%s\n' "${commands[@]}" | parallel --max-procs "$v_parallel_procs" --line-buffer
}

function video_filters {
  local video_filters=()

  if [[ -n $v_deinterlace ]]; then
    video_filters+=("yadif=mode=0")
  fi

  if [[ -n $v_dar_ratio ]]; then
    local dar_wh=$v_dar_ratio dar_hw=${v_dar_ratio#*/}/${v_dar_ratio%/*}
    video_filters+=("scale='min(iw,ih*$dar_wh)':'round(min(ih,iw*$dar_hw)/2)*2',setsar=1")
  fi

  if [[ -n $v_resize ]]; then
    video_filters+=("scale=-2:$v_resize")
  fi

  if [[ -n $v_rotate ]]; then
    video_filters+=("${c_rotation_to_filter[$v_rotate]}")
  fi

  if [[ ${#video_filters[@]} -gt 0 ]]; then
    local IFS=,
    echo "${video_filters[*]}"
  fi
}

function video_codec_options {
  local video_codec_options
  if [[ $v_video_codec == h265 ]]; then
    video_codec_options="-c:v libx265 -crf $v_crf -preset $v_preset -pix_fmt yuv420p10le"
  else
    video_codec_options="-c:v libsvtav1 -crf $v_crf -preset $v_preset -pix_fmt yuv420p10le -svtav1-params tune=0"
  fi
  echo "$video_codec_options"
}

function hwaccel_options {
  # Hardware decoding is not enabled automatically; without this, codecs whose ffmpeg decoder is
  # hwaccel-only (e.g. AV1 on builds without libdav1d) fail to decode. For codecs the GPU can't
  # handle, ffmpeg falls back to software decoding.
  local hwaccel=vaapi hwaccel_device_option=()
  if [[ $OSTYPE == darwin* ]]; then
    hwaccel=videotoolbox
  else
    # VAAPI defaults to renderD128, which on a multi-GPU system may be an NVIDIA card (no VAAPI
    # support). Pick the first render node not bound to the nvidia driver (i.e. the iGPU/AMD/Intel).
    local node driver
    for node in /dev/dri/renderD*; do
      driver=$(basename "$(readlink -f "/sys/class/drm/${node##*/}/device/driver")")
      if [[ $driver != nvidia ]]; then
        hwaccel_device_option=(-hwaccel_device "$node")
        break
      fi
    done
  fi

  echo "-hwaccel $hwaccel ${hwaccel_device_option[*]}"
}

function shell_quote {
  printf '%q' "$1"
}

function build_ffmpeg_command {
  local input_file=$1 segments=$2 output_file=$3
  local global_options= output_options=

  if [[ -n $v_rotate ]]; then
    global_options="-noautorotate"
    output_options="-metadata:s:v:0 rotate=0"
  fi

  if [[ -n $segments && $segments == *,* ]]; then
    build_multi_segment_ffmpeg_command "$input_file" "$segments" "$output_file" "$global_options" "$output_options"
  else
    build_single_segment_ffmpeg_command "$input_file" "$segments" "$output_file" "$global_options" "$output_options"
  fi
}

function build_single_segment_ffmpeg_command {
  local input_file=$1 segment=$2 output_file=$3 global_options=$4 output_options=$5
  local video_options=()

  if [[ -n $segment ]]; then
    local start_segment=${segment%-*}
    local end_segment=${segment#*-}

    if [[ -n $start_segment ]]; then
      video_options+=("-ss" "$start_segment")
    fi
    if [[ -n $end_segment ]]; then
      video_options+=("-to" "$end_segment")
    fi
  fi

  local video_filters_par=()
  local filters
  filters=$(video_filters)
  if [[ -n $filters ]]; then
    video_filters_par=(-vf "$filters")
  fi

  printf 'ffmpeg %s %s -i %s %s -c:a copy %s %s %s %s' \
    "$global_options" \
    "$(hwaccel_options)" \
    "$(shell_quote "$input_file")" \
    "$(printf '%q ' "${video_options[@]}")" \
    "$(printf '%q ' "${video_filters_par[@]}")" \
    "$(video_codec_options)" \
    "$output_options" \
    "$(shell_quote "$output_file")"
}

function build_multi_segment_ffmpeg_command {
  local input_file=$1 segments=$2 output_file=$3 global_options=$4 output_options=$5
  local has_audio=

  if ffprobe -v error -select_streams a:0 -show_entries stream=codec_type -of default=noprint_wrappers=1:nokey=1 "$input_file" | grep -qx audio; then
    has_audio=1
  fi

  local filter_complex
  filter_complex=$(build_multi_segment_filter_complex "$segments" "$has_audio")

  local audio_options="-an"
  if [[ -n $has_audio ]]; then
    audio_options="-map $(shell_quote '[aout]') -c:a aac"
  fi

  printf 'ffmpeg %s %s -i %s -filter_complex %s -map %s %s %s %s %s' \
    "$global_options" \
    "$(hwaccel_options)" \
    "$(shell_quote "$input_file")" \
    "$(shell_quote "$filter_complex")" \
    "$(shell_quote '[vout]')" \
    "$audio_options" \
    "$(video_codec_options)" \
    "$output_options" \
    "$(shell_quote "$output_file")"
}

function build_multi_segment_filter_complex {
  local segments=$1 has_audio=$2
  local parts=() concat_inputs=() split_segments segment start_segment end_segment trim_options

  IFS=, read -ra split_segments <<< "$segments"
  for (( i = 0; i < "${#split_segments[@]}"; i++ )); do
    segment=${split_segments[$i]}
    start_segment=${segment%-*}
    end_segment=${segment#*-}
    trim_options=()

    [[ -n $start_segment ]] && trim_options+=("start=$(timestamp_to_seconds "$start_segment")")
    [[ -n $end_segment ]] && trim_options+=("end=$(timestamp_to_seconds "$end_segment")")

    parts+=("[0:v]trim=$(IFS=:; echo "${trim_options[*]}"),setpts=PTS-STARTPTS[v$i]")
    concat_inputs+=("[v$i]")

    if [[ -n $has_audio ]]; then
      parts+=("[0:a]atrim=$(IFS=:; echo "${trim_options[*]}"),asetpts=PTS-STARTPTS[a$i]")
      concat_inputs+=("[a$i]")
    fi
  done

  if [[ -n $has_audio ]]; then
    parts+=("$(IFS=; echo "${concat_inputs[*]}")concat=n=${#split_segments[@]}:v=1:a=1[vconcat][aout]")
  else
    parts+=("$(IFS=; echo "${concat_inputs[*]}")concat=n=${#split_segments[@]}:v=1:a=0[vconcat]")
  fi

  local filters
  filters=$(video_filters)
  if [[ -n $filters ]]; then
    parts+=("[vconcat]${filters}[vout]")
  else
    parts+=("[vconcat]null[vout]")
  fi

  local IFS=';'
  echo "${parts[*]}"
}

function timestamp_to_seconds {
  LC_ALL=C awk -F: '
    NF == 1 { print $1 }
    NF == 2 { print $1 * 60 + $2 }
    NF == 3 { print $1 * 3600 + $2 * 60 + $3 }
  ' <<< "$1"
}

function trash_original_files {
  for file in "${v_temp_input_files[@]}"; do
    trash "$file"
  done
}

function list_files {
  echo

  for ((i = 0; i < "${#v_temp_input_files[@]}"; i++)); do
    # shellcheck disable=2012 # find has no advantage here
    # shellcheck disable=2016 # $ in the single quotes are not expressions
    (
      ls -lh --sort=none "${v_temp_input_files[$i]}"
      ls -lh --sort=none "${v_output_files[$i]}"
    ) \
    | ruby -ane 'puts "#{$F[4]}\t #{File.basename($F[8..].join(" "))}"'
  done

  echo
}

function main {
  # Since all files are moved, if one accidentally selects other many/large files and interrupts, they
  # may leave the files half moved.
  # In order to avoid this, we check the files first.
  check_input_files

  # First move the files, as the error exit hook assumes it. For simplicity, if there is an interruption
  # or error while moving, we let the use handle it.
  rename_input_files

  register_exit_hooks
  perform_checks
  encode_files
  if [[ -z $v_batch_mode ]]; then
    list_files
    "${SCRIPTING_ALARM_PROGRAM:-true}"
  fi
  if [[ -n $v_delete_input_files ]]; then
    trash_original_files
  fi
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  decode_cmdline_args "$@"
  main
fi
